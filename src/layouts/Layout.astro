---
import ConsoleSignature from '../components/ConsoleSignature.astro';
import SEO from '../components/SEO.astro';
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalURL?: URL;
  lang?: string;
}

const { title, description, image, canonicalURL, lang = 'en' } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <SEO {title} {description} {image} {canonicalURL} />
    <ClientRouter />
  </head>
  <body>
    <slot />
    <ConsoleSignature />
  </body>
</html>
