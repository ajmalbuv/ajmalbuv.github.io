---
import { Icon } from "astro-icon/components";
import { PersonalDetails } from "../data/PersonalDetails";
import SafeLink from "./SafeLink.astro";
const contacts = PersonalDetails.contact;
---

<section
  class="flex flex-col lg:flex-row justify-evenly mt-10 mx-3 lg:mb-[50px] w-full"
  id="contact"
>
  <div
    class="side1 flex flex-col justify-center items-center h-[200px] lg:w-1/2 lg:h-[60vh]"
  >
    <p class="text-2xl font-semibold text-center">
      Let's do a <span class="text-5xl">PROJECT</span> together.
    </p>
    <div class="flex justify-center items-center">
      <p class="text-2xl font-semibold">Let's Chat.</p>
      <p class="text-4xl font-semibold pl-3">HIRE ME!</p>
    </div>
  </div>

  <div class="side2 lg:w-[40%]">
    <div class="flex justify-center border-2 p-3">
      <form id="contact-form" class="w-full">
        <div class="flex flex-col lg:flex-row lg:justify-between">
          <div class="lg:w-[48%]">
            <label for="firstname" class="block mb-[5px] text-white"
              >First Name:</label
            >
            <input
              type="text"
              id="firstname"
              name="firstname"
              required
              autocomplete="given-name"
              class="w-full p-2 mb-2 border border-gray-300 rounded bg-white text-black"
            />
          </div>
          <div class="lg:w-[48%]">
            <label for="lastname" class="block mb-[5px] text-white"
              >Last Name:</label
            >
            <input
              type="text"
              id="lastname"
              name="lastname"
              required
              autocomplete="family-name"
              class="w-full p-2 mb-2 border border-gray-300 rounded bg-white text-black"
            />
          </div>
        </div>
        <div class="mt-2">
          <label for="email" class="block mb-[5px] text-white">Email:</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            autocomplete="email"
            class="w-full p-2 mb-2 border border-gray-300 rounded bg-white text-black"
          />
        </div>
        <div class="mt-2">
          <label for="ph" class="block mb-[5px] text-white"
            >Mobile Number:</label
          >
          <input
            type="tel"
            id="ph"
            name="ph"
            required
            autocomplete="tel"
            class="w-full p-2 mb-2 border border-gray-300 rounded bg-white text-black"
          />
        </div>
        <div class="mt-2">
          <label for="message" class="block mb-[5px] text-white">Message:</label
          >
          <textarea
            id="message"
            name="message"
            required
            class="w-full p-2 mb-[15px] border border-gray-300 rounded bg-white h-[150px] text-black"
          ></textarea>
        </div>
        <div class="mt-2">
          <input
            type="submit"
            value="Send Mail"
            class="bg-white text-violet-900 px-5 py-2 border-none rounded cursor-pointer text-lg transition-transform duration-1000 hover:translate-x-4 hover:bg-violet-500 hover:text-white focus-visible:translate-x-4"
          />
        </div>
      </form>
    </div>

    {
      contacts && (
        <div class="social-bar flex justify-evenly items-center border-2 p-2 rounded-full mt-5 min-h-[50px] lg:absolute lg:bottom-5 lg:left-[100px] lg:w-[40%]">
          <SafeLink
            href={`mailto:${contacts.email.id}`}
            title={contacts.email.id}
            class="flex items-center justify-center cursor-pointer"
            aria-label="Send Email"
          >
            <Icon
              name={contacts.email.icon}
              class="h-[30px] w-[30px] object-contain"
            />
          </SafeLink>
          <SafeLink
            href={`tel:${contacts.phone.number}`}
            title={contacts.phone.number}
            class="flex items-center justify-center cursor-pointer"
            aria-label="Call Phone"
          >
            <Icon
              name={contacts.phone.icon}
              class="h-[30px] w-[30px] object-contain"
            />
          </SafeLink>
          <SafeLink
            href={contacts.instagram.url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="flex items-center justify-center"
          >
            <Icon
              name={contacts.instagram.icon}
              class="h-[30px] w-[30px] object-contain"
            />
          </SafeLink>
          <SafeLink
            href={contacts.github.url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Github"
            class="flex items-center justify-center"
          >
            <Icon
              name={contacts.github.icon}
              class="h-[30px] w-[30px] object-contain"
            />
          </SafeLink>
          <SafeLink
            href={contacts.linkedin.url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="flex items-center justify-center"
          >
            <Icon
              name={contacts.linkedin.icon}
              class="h-[30px] w-[30px] object-contain"
            />
          </SafeLink>
        </div>
      )
    }
  </div>
</section>

<style>
  .text-2xl {
    font-size: clamp(1.15rem, 2vw, 2rem);
  }

  .text-5xl {
    font-size: clamp(2rem, 5vw, 5rem);
  }

  @media (prefers-reduced-motion: no-preference) {
    #contact {
      scale: 0.6;
      opacity: 0;
      animation: fade-anim linear forwards;
      animation-timeline: view();
      animation-range: entry;
    }

    @keyframes fade-anim {
      to {
        opacity: 1;
        scale: 1;
      }
    }
  }

  @media (max-width: 1024px) {
    .side1,
    .side2 {
      scale: 0.8;
      opacity: 0;
      animation: fade-anim-mobile linear forwards;
      animation-timeline: view();
      animation-range: entry;
    }

    @keyframes fade-anim-mobile {
      to {
        opacity: 1;
        scale: 1;
      }
    }
  }
</style>

<script>
  import emailjs from "@emailjs/browser";

  function initContact() {
    const PUBLIC_KEY = import.meta.env.PUBLIC_EMAILJS_PUBLIC_KEY;
    const SERVICE_ID = import.meta.env.PUBLIC_EMAILJS_SERVICE_ID;
    const TEMPLATE_ID = import.meta.env.PUBLIC_EMAILJS_TEMPLATE_ID;

    if (PUBLIC_KEY) {
      emailjs.init(PUBLIC_KEY);
    }

    const contactForm = document.getElementById(
      "contact-form",
    ) as HTMLFormElement;

    if (contactForm && !contactForm.dataset.initialized) {
      contactForm.dataset.initialized = "true";
      contactForm.addEventListener("submit", (e) => {
        e.preventDefault();

        if (!PUBLIC_KEY || !SERVICE_ID || !TEMPLATE_ID) {
          alert(
            "EmailJS keys are not configured. Please check your environment variables.",
          );
          return;
        }

        const formData = new FormData(contactForm);
        const templateParams = {
          name: `${formData.get("firstname")} ${formData.get("lastname")}`,
          email: formData.get("email"),
          ph: formData.get("ph"),
          message: formData.get("message"),
        };

        emailjs
          .send(SERVICE_ID, TEMPLATE_ID, templateParams)
          .then(() => {
            alert("Mail sent successfully!");
            contactForm.reset();
          })
          .catch((error) => {
            console.error("FAILED...", error);
            alert("An error occurred while sending the email.");
          });
      });
    }
  }

  initContact();
  document.addEventListener("astro:after-swap", initContact);
</script>
