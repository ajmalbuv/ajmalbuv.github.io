---
import { Icon } from "astro-icon/components";
import { PersonalDetails } from "../data/PersonalDetails";
const contacts = PersonalDetails.contact;
---

<section class="flex flex-col justify-evenly mt-10 mx-3" id="contact">
  <div class="side1 flex flex-col justify-center items-center h-[200px]">
    <p class="text-2xl font-semibold">
      Let's do a <span class="text-5xl">PROJECT</span> together.
    </p>
    <div class="flex justify-center items-center">
      <p class="text-2xl font-semibold">Let's Chat.</p>
      <p class="text-4xl font-semibold pl-3">HIRE ME!</p>
    </div>
  </div>
  <div class="side2">
    <div class="flex justify-center border-2 p-3">
      <form id="contact-form" class="w-full">
        <div class="form-group-name">
          <div>
            <label for="firstname">First Name:</label>
            <input type="text" id="firstname" name="firstname" required autocomplete="given-name" />
          </div>
          <div>
            <label for="lastname">Last Name:</label>
            <input type="text" id="lastname" name="lastname" required autocomplete="family-name" />
          </div>
        </div>
        <div class="form-group">
          <label for="email">Email:</label>
          <input type="email" id="email" name="email" required autocomplete="email" />
        </div>
        <div class="form-group">
          <label for="ph">Mobile Number:</label>
          <input type="tel" id="ph" name="ph" required autocomplete="tel" />
        </div>
        <div class="form-group">
          <label for="message">Message:</label>
          <textarea id="message" name="message" required></textarea>
        </div>
        <div class="form-group">
          <input type="submit" value="Send Mail" />
        </div>
      </form>
    </div>

    {
      contacts && (
        <div class="social-bar flex justify-evenly items-center border-2 p-2 rounded-full mt-5 min-h-[50px]">
          <a
            href={`mailto:${contacts.email.id}`}
            title={contacts.email.id}
            class="flex items-center justify-center cursor-pointer"
            aria-label="Send Email"
          >
            <Icon
              name={contacts.email.img as string}
              class="h-[30px] w-[30px] object-contain"
            />
          </a>
          <a
            href={`tel:${contacts.phone.number}`}
            title={contacts.phone.number}
            class="flex items-center justify-center cursor-pointer"
            aria-label="Call Phone"
          >
            <Icon
              name={contacts.phone.img as string}
              class="h-[30px] w-[30px] object-contain"
            />
          </a>
          <a
            href={contacts.instagram.url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="flex items-center justify-center"
          >
            <Icon
              name={contacts.instagram.img as string}
              class="h-[30px] w-[30px] object-contain"
            />
          </a>
          <a
            href={contacts.github.url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Github"
            class="flex items-center justify-center"
          >
            <Icon
              name={contacts.github.img as string}
              class="h-[30px] w-[30px] object-contain"
            />
          </a>
          <a
            href={contacts.linkedin.url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="flex items-center justify-center"
          >
            <Icon
              name={contacts.linkedin.img as string}
              class="h-[30px] w-[30px] object-contain"
            />
          </a>
        </div>
      )
    }
  </div>
</section>

<style>
  .text-2xl {
    font-size: clamp(1.15rem, 2vw, 2rem);
  }

  .text-5xl {
    font-size: clamp(2rem, 5vw, 5rem);
  }

  label {
    display: block;
    margin-bottom: 5px;
    color: #ffffff;
  }

  input[type="text"] {
    width: 100%;
    padding: 8px;
    margin-bottom: 8px;
    border: 1px solid #ccc;
    border-radius: 4px;
    box-sizing: border-box;
    background-color: white;
    color: rgb(0, 0, 0);
  }

  textarea {
    width: 100%;
    padding: 8px;
    margin-bottom: 15px;
    border: 1px solid #ccc;
    border-radius: 4px;
    box-sizing: border-box;
    background-color: white;
    height: 150px;
    color: rgb(0, 0, 0);
  }

  input[type="submit"] {
    background-color: #ffffff;
    color: #4c1d95;
    padding: 10px 20px;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-size: 16px;
  }

  .form-group-name {
    display: flex;
    flex-direction: column;
  }

  @media (min-width: 1025px) {
    section {
      flex-direction: row;
      width: 100%;
      margin-bottom: 50px;
    }

    section > div:nth-child(1) {
      width: 50%;
      height: 60vh;
    }

    section > div:nth-child(2) {
      width: 40%;
    }

    .social-bar {
      position: absolute;
      bottom: 20px;
      left: 100px;
      width: 40%;
    }

    .form-group-name {
      flex-direction: row;
      justify-content: space-between;
    }

    .form-group-name div {
      width: 48%;
    }

    @media (prefers-reduced-motion: no-preference) {
      #contact {
        scale: 0.6;
        opacity: 0;
        animation: fade-anim linear forwards;
        animation-timeline: view();
        animation-range: entry;
      }

      @keyframes fade-anim {
        to {
          opacity: 1;
          scale: 1;
        }
      }
    }
  }

  .side2 input[type="submit"] {
    transition: transform 1000ms;
  }

  .side2 input[type="submit"]:hover,
  .side2 input[type="submit"]:focus-visible {
    transform: translateX(1rem);
    background-color: #8b5cf6;
    color: white;
  }

  @media (max-width: 1024px) {
    .side1 {
      scale: 0.6;
      opacity: 0;
      animation: fade-anim linear forwards;
      animation-timeline: view();
      animation-range: entry;
    }

    .side2 {
      scale: 0.8;
      opacity: 0;
      animation: fade-anim linear forwards;
      animation-timeline: view();
      animation-range: entry;
    }

    @keyframes fade-anim {
      to {
        opacity: 1;
        scale: 1;
      }
    }
  }
</style>

<script>
  import emailjs from "@emailjs/browser";

  // EmailJS Logic using Astro Environment Variables
  const PUBLIC_KEY = import.meta.env.PUBLIC_EMAILJS_PUBLIC_KEY;
  const SERVICE_ID = import.meta.env.PUBLIC_EMAILJS_SERVICE_ID;
  const TEMPLATE_ID = import.meta.env.PUBLIC_EMAILJS_TEMPLATE_ID;

  if (PUBLIC_KEY) {
    emailjs.init(PUBLIC_KEY);
  }

  const contactForm = document.getElementById(
    "contact-form",
  ) as HTMLFormElement;

  contactForm?.addEventListener("submit", (e) => {
    e.preventDefault();

    if (!PUBLIC_KEY || !SERVICE_ID || !TEMPLATE_ID) {
      alert(
        "EmailJS keys are not configured. Please check your environment variables.",
      );
      return;
    }

    const formData = new FormData(contactForm);
    const templateParams = {
      name: `${formData.get("firstname")} ${formData.get("lastname")}`,
      email: formData.get("email"),
      ph: formData.get("ph"),
      message: formData.get("message"),
    };

    emailjs
      .send(SERVICE_ID, TEMPLATE_ID, templateParams)
      .then(() => {
        alert("Mail sent successfully!");
        contactForm.reset();
      })
      .catch((error) => {
        console.error("FAILED...", error);
        alert("An error occurred while sending the email.");
      });
  });
</script>
